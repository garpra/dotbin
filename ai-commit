#!/bin/bash
# ai-commit.sh
#
# Generate professional git commit messages using Gemini Cli
# Reads codebase context + git changes, outputs message to terminal
#
# Usage:
#   ./ai-commit.sh
#   ./ai-commit.sh --lang Indonesian

set -euo pipefail

# ============================================
# Colors for output
# ============================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# ============================================
# Configuration
# ============================================
OUTPUT_LANG="English"
VERBOSE=false
MODEL="gemini-2.5-flash-lite"
MAX_DIFF_BYTES=20000

# ============================================
# Parse arguments
# ============================================
while [[ $# -gt 0 ]]; do
  case $1 in
  --lang)
    OUTPUT_LANG="$2"
    shift 2
    ;;
  --verbose)
    VERBOSE=true
    shift
    ;;
  --help)
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --lang LANG       Output language (default: English)"
    echo "  --verbose         Show debug information"
    echo "  --help            Show this help message"
    echo ""
    echo "Examples:"
    echo "  ./ai-commit.sh                    # English output"
    echo "  ./ai-commit.sh --lang Indonesian  # Indonesian output"
    echo ""
    exit 0
    ;;
  *)
    echo "Unknown option: $1"
    exit 1
    ;;
  esac
done

# ============================================
# Helper functions
# ============================================
log_info() {
  echo -e "${BLUE} $1${NC}"
}

log_success() {
  echo -e "${GREEN} $1${NC}"
}

log_warning() {
  echo -e "${YELLOW} $1${NC}"
}

log_error() {
  echo -e "${RED} $1${NC}"
}

debug_log() {
  if [ "$VERBOSE" = true ]; then
    echo -e "${CYAN}[DEBUG] $1${NC}"
  fi
}

# ============================================
# Verify git repository
# ============================================
if ! git rev-parse --git-dir >/dev/null 2>&1; then
  log_error "Not a git repository. Please run this script from a git project root."
  exit 1
fi

log_info "Git repository found: $(git rev-parse --show-toplevel)"

# ============================================
# Verify Gemini Cli is installed
# ============================================
if ! command -v gemini &>/dev/null; then
  log_error "Gemini Cli is not installed. Please install with: npm install -g @google/gemini-cli@latest"
  exit 1
fi

debug_log "Gemini Cli found at: $(which gemini)"

# ============================================
# Check if there are staged changes
# ============================================
STAGED_DIFF=$(git diff --cached 2>/dev/null || true)

if [ -z "$STAGED_DIFF" ]; then
  log_warning "No staged changes found. Use 'git add' to stage files."
  echo ""
  echo "To generate a commit message, first stage your changes:"
  echo "  git add <file>    # Stage specific files"
  echo "  git add .         # Stage all changes"
  exit 1
fi

log_success "Found staged changes"
debug_log "Staged diff size: $(echo "$STAGED_DIFF" | wc -l) lines"

# ============================================
# Get additional context
# ============================================

# Git status (short format)
GIT_STATUS=$(git status --short)
debug_log "Git status:\n$GIT_STATUS"

# Last few commits for context
RECENT_COMMITS=$(git log --oneline -5 2>/dev/null || echo "No previous commits")
debug_log "Recent commits:\n$RECENT_COMMITS"

# Current branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
debug_log "Current branch: $CURRENT_BRANCH"

# Staged files list
STAGED_FILES=$(git diff --cached --name-only)
debug_log "Staged files:\n$STAGED_FILES"

# Get file count and change stats
CHANGE_STATS=$(git diff --cached --stat)
debug_log "Change stats:\n$CHANGE_STATS"

# ============================================
# Build context for AI
# ============================================
log_info "Analyzing changes and generating commit message..."
echo ""

# Truncate very large diffs (if diff is too big, take only first 20KB)
if [ ${#STAGED_DIFF} -gt "$MAX_DIFF_BYTES" ]; then
  log_warning "Diff is very large, truncating to first ${MAX_DIFF_BYTES}B for analysis"
  STAGED_DIFF_TRUNCATED=$(echo "$STAGED_DIFF" | head -c "$MAX_DIFF_BYTES")
  STAGED_DIFF_TRUNCATED="$STAGED_DIFF_TRUNCATED\n[... diff truncated due to size ...]"
else
  STAGED_DIFF_TRUNCATED="$STAGED_DIFF"
fi

# Build the prompt for Gemini Cli
PROMPT="Write a git commit message for these staged changes.

Files changed:
$STAGED_FILES

Diff:
$STAGED_DIFF

Rules:
- Conventional Commits format: <type>(<scope>): <subject>
- Types: feat, fix, docs, style, refactor, test, chore, perf, ci
- Subject: max 72 chars, imperative mood, no period
- Add body only if change is complex or non-obvious
- Language: $OUTPUT_LANG

Output ONLY the commit message, no explanation, no code blocks."

# ============================================
# Call Gemini Cli
# ============================================
debug_log "Sending prompt to Gemini Cli..."

COMMIT_MESSAGE=$(gemini -m "$MODEL" -p "$PROMPT" --output-format text 2>/dev/null || true)

if [ -z "$COMMIT_MESSAGE" ]; then
  log_error "Failed to generate commit message from Gemini Cli"
  log_info "Make sure you are authenticated: gemini /auth"
  exit 1
fi

# ============================================
# Output the result
# ============================================
echo ""
echo -e "${CYAN}════════════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}Generated Commit Message:${NC}"
echo -e "${CYAN}════════════════════════════════════════════════════════════════${NC}"
echo ""

# Text output
echo "$COMMIT_MESSAGE"
echo ""

echo -e "${CYAN}════════════════════════════════════════════════════════════════${NC}"
echo ""

# ============================================
# Statistics
# ============================================
log_info "Change summary:"
echo "$CHANGE_STATS" | tail -1
echo ""

log_success "Ready to commit! Copy the message above and use 'git commit -m' with the text."
